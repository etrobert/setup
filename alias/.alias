# vim: ft=sh

# Aliases

falias() {
  local selected
  selected=$(
    alias |
      sed "s/^alias //" |
      sed "s/='/=/" |
      sed "s/'$//" |
      column -t -s '=' |
      fzf |
      awk '{print $1}'
  )
  if [ -n "$selected" ]; then
    eval "$selected"
  fi
}

nixplatforms() {
  nix eval nixpkgs#"$1".meta.platforms --json
}

batr() {
  find "$1" -type f -exec bat {} +
}
