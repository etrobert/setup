#compdef tmux-sessionizer ts

local state
local -a projects

projects=(setup doc)
[[ -d $HOME/work ]] && projects+=($HOME/work/*(N/:t))

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-e --existing)'{-e,--existing}'[show only existing tmux sessions]' \
  ':project:->project'

case $state in
  project) compadd -a projects ;;
esac
